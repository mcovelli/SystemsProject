# -----------------------------------------
# SENSITIVE FILES (NEVER COMMIT)
# -----------------------------------------
*.pem
*.key
*.crt
*.p12
config.php
config-local.php
secrets/
.env
.env.*

# -----------------------------------------
# PHP / TEMP / LOG FILES
# -----------------------------------------
*.log
*.cache
*.tmp
*.bak
*.swp
*.DS_Store

# php error logs
php_errors.log
error_log

# Composer dependencies (if used later)
vendor/

# -----------------------------------------
# NODE / JS BUILD FILES (if used later)
# -----------------------------------------
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
dist/
build/

# -----------------------------------------
# SYSTEM / OS FILES
# -----------------------------------------
Thumbs.db
desktop.ini

# -----------------------------------------
# IDE / EDITOR FILES
# -----------------------------------------
# VSCode
.vscode/
.history/

# PhpStorm / JetBrains
.idea/
*.iml

# Sublime
*.sublime-workspace
*.sublime-project

# -----------------------------------------
# MISC
# -----------------------------------------
# Ignore backup directories
backup/
tmp/
temp/
uploads/
