# ================================
#  PHP / Web App Ignore Rules
# ================================

# Sensitive config files
config.php
*.env
.env.*

# Local database dumps or seeds
*.sql
*.sqlite

# Backup archives
*.tar
*.tar.gz
*.zip
*.bak
*.backup
backups/
home/ubuntu/backups/

# Logs and debug files
*.log
error_log
logs/
*.tmp
*.swp

# Apache / server files
.htaccess
.htpasswd

# Node / front-end build (if added later)
node_modules/
dist/
build/

# ================================
#  IDE / OS / System Files
# ================================

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
.DS_Store
ehthumbs.db
Desktop.ini

# VS Code
.vscode/
*.code-workspace

# JetBrains IDEs (PHPStorm, IntelliJ)
.idea/
*.iml
out/

# Temporary / compiled cache
vendor/
composer.lock
__pycache__/
*.pyc

# ================================
#  Deployment / Server Scripts
# ================================

# Deployment scripts are server-only
deploy.sh
*.pem
*.key
*.crt
*.csr

# ================================
#  Miscellaneous
# ================================

# Local test data or exports
/tmp/
tAest_output/
